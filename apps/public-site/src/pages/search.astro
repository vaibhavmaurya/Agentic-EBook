---
import Base from '../layouts/Base.astro'
import { getJson } from '../lib/s3'
import type { SearchIndex } from '../lib/types'

let searchIndex: SearchIndex = { generated_at: '', topic_count: 0, documents: [] }
try {
  searchIndex = await getJson<SearchIndex>('site/current/search/index.json')
} catch { /* no published content yet */ }

// Inline the documents JSON into the page for client-side Lunr indexing
const docsJson = JSON.stringify(searchIndex.documents)
---
<Base title="Search — Ebook">
  <main style="max-width:760px;margin:0 auto;padding:48px 24px;">
    <h1 style="font-size:1.75rem;margin-bottom:8px;">Search</h1>
    <p style="color:var(--color-muted);font-size:14px;margin-bottom:28px;">
      {searchIndex.topic_count} chapter{searchIndex.topic_count !== 1 ? 's' : ''} indexed
    </p>

    <div style="position:relative;margin-bottom:32px;">
      <input
        id="search-input"
        type="search"
        placeholder="Search chapters…"
        autofocus
        style="width:100%;padding:12px 16px;font-size:16px;border:2px solid var(--color-border);border-radius:var(--radius);font:inherit;outline:none;"
        onfocus="this.style.borderColor='var(--color-primary)'"
        onblur="this.style.borderColor='var(--color-border)'"
      />
    </div>

    <div id="search-results"></div>
  </main>

  <script define:vars={{ docsJson }}>
    // Import lunr lazily — avoids Astro SSR issues
    async function initSearch() {
      const { default: lunr } = await import('/node_modules/lunr/lunr.js')
      const docs = JSON.parse(docsJson)

      if (!docs.length) {
        document.getElementById('search-results').innerHTML =
          '<p style="color:var(--color-muted)">No content indexed yet.</p>'
        return
      }

      const idx = lunr(function () {
        this.ref('id')
        this.field('title', { boost: 10 })
        this.field('body')
        docs.forEach((d) => this.add(d))
      })

      const byId = Object.fromEntries(docs.map((d) => [d.id, d]))

      function render(results) {
        if (!results.length) {
          return '<p style="color:var(--color-muted)">No results found.</p>'
        }
        return results.map(({ ref }) => {
          const doc = byId[ref]
          if (!doc) return ''
          return `
            <a href="/topics/${doc.slug}" style="display:block;padding:20px;background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);text-decoration:none;color:var(--color-text);margin-bottom:12px;">
              <strong style="font-size:1rem;">${doc.title}</strong>
              <p style="font-size:14px;color:var(--color-muted);margin-top:4px;">${doc.body.slice(0, 120)}…</p>
            </a>`
        }).join('')
      }

      const input = document.getElementById('search-input')
      const resultsEl = document.getElementById('search-results')

      input.addEventListener('input', () => {
        const q = input.value.trim()
        if (!q) { resultsEl.innerHTML = ''; return }
        try {
          resultsEl.innerHTML = render(idx.search(q + '~1'))
        } catch {
          resultsEl.innerHTML = render(idx.search(q))
        }
      })

      // Run initial search if query param present
      const urlQ = new URLSearchParams(location.search).get('q')
      if (urlQ) { input.value = urlQ; input.dispatchEvent(new Event('input')) }
    }

    initSearch()
  </script>
</Base>
