---
import Base from '../layouts/Base.astro'
---
<Base title="Release Notes — Ebook">
  <main style="max-width:760px;margin:0 auto;padding:48px 24px;">
    <h1 style="font-size:1.75rem;margin-bottom:8px;">Release Notes</h1>
    <p style="color:var(--color-muted);font-size:14px;margin-bottom:32px;">
      A history of published and updated chapters.
    </p>

    <div id="releases-loading" style="color:var(--color-muted);">Loading…</div>
    <div id="releases-empty" style="display:none;color:var(--color-muted);">No chapters published yet.</div>
    <div id="releases-list" style="display:none;flex-direction:column;gap:32px;"></div>
  </main>

  <script>
    const API_BASE = import.meta.env.PUBLIC_API_BASE_URL || ''

    function fmtDate(iso: string) {
      if (!iso) return ''
      return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
    }

    async function loadReleases() {
      try {
        const res = await fetch(`${API_BASE}/public/releases/latest`)
        if (!res.ok) throw new Error(`HTTP ${res.status}`)
        const data = await res.json()
        const releases: any[] = data.releases || []

        document.getElementById('releases-loading')!.style.display = 'none'

        if (releases.length === 0) {
          document.getElementById('releases-empty')!.style.display = 'block'
          return
        }

        const list = document.getElementById('releases-list')!
        list.style.display = 'flex'

        releases.forEach((r) => {
          const div = document.createElement('div')
          div.innerHTML = `
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;flex-wrap:wrap;">
              <span class="badge">${r.version || ''}</span>
              <span style="font-size:13px;color:var(--color-muted);">${fmtDate(r.published_at)}</span>
            </div>
            <h2 style="font-size:1.1rem;margin-bottom:6px;">
              <a href="/topic?id=${encodeURIComponent(r.topic_id)}" style="color:var(--color-text);">${r.title || ''}</a>
            </h2>
            ${r.release_notes
              ? `<p style="font-size:14px;color:var(--color-muted);">${r.release_notes}</p>`
              : `<p style="font-size:14px;color:var(--color-muted);font-style:italic;">No release notes.</p>`
            }`
          list.appendChild(div)
        })
      } catch {
        document.getElementById('releases-loading')!.style.display = 'none'
        document.getElementById('releases-empty')!.style.display = 'block'
      }
    }

    loadReleases()
  </script>
</Base>
