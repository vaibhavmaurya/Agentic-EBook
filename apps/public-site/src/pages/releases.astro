---
import Base from '../layouts/Base.astro'
import { getJson } from '../lib/s3'
import type { TocData } from '../lib/types'

let toc: TocData = { generated_at: '', topic_count: 0, topics: [] }
try {
  toc = await getJson<TocData>('site/current/toc.json')
} catch {}

// Sort by published_at descending
const recent = [...toc.topics].sort((a, b) =>
  new Date(b.published_at).getTime() - new Date(a.published_at).getTime()
)

function fmtDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
}
---
<Base title="Release Notes — Ebook">
  <main style="max-width:760px;margin:0 auto;padding:48px 24px;">
    <h1 style="font-size:1.75rem;margin-bottom:8px;">Release Notes</h1>
    <p style="color:var(--color-muted);font-size:14px;margin-bottom:32px;">
      A history of published and updated chapters.
    </p>

    {recent.length === 0 ? (
      <p style="color:var(--color-muted);">No chapters published yet.</p>
    ) : (
      <div style="display:flex;flex-direction:column;gap:32px;">
        {recent.map((topic) => (
          <div>
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;flex-wrap:wrap;">
              <span class="badge">{topic.version}</span>
              <span style="font-size:13px;color:var(--color-muted);">{fmtDate(topic.published_at)}</span>
            </div>
            <h2 style="font-size:1.1rem;margin-bottom:6px;">
              <a href={`/topics/${topic.slug}`}>{topic.title}</a>
            </h2>
            {topic.release_notes ? (
              <p style="font-size:14px;color:var(--color-muted);">{topic.release_notes}</p>
            ) : (
              <p style="font-size:14px;color:var(--color-muted);font-style:italic;">No release notes.</p>
            )}
          </div>
        ))}
      </div>
    )}
  </main>
</Base>
