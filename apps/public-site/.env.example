# Copy to .env.local — all PUBLIC_ vars are inlined at build time by Astro
# S3 artifact bucket (used at build time to fetch toc.json and content.md)
S3_ARTIFACT_BUCKET=ebook-platform-artifacts-dev
AWS_REGION=us-east-1

# Public API base URL (used at runtime for comments/highlights)
PUBLIC_API_BASE_URL=http://localhost:8000

# Site canonical URL (for meta tags and sitemap)
SITE=http://localhost:4321
