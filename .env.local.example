# =============================================================================
# Agentic Ebook Platform V3 — Local Development Environment Template
# =============================================================================
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — NEVER commit it.
#
# IMPORTANT: Do NOT put comments on the same line as a value.
# dotenv parses "KEY=value  # comment" with the comment as part of the value.
# Always put comments on their own line above the variable.
# =============================================================================

# AWS Credentials (dev account only)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only needed if using temporary credentials (SSO, assume-role):
AWS_SESSION_TOKEN=
# Both vars needed: boto3 uses AWS_REGION, application code reads AWS_REGION_NAME
AWS_REGION=us-east-1
AWS_REGION_NAME=us-east-1
AWS_ACCOUNT_ID=

# DynamoDB
DYNAMODB_TABLE_NAME=ebook-platform-dev

# S3
S3_ARTIFACT_BUCKET=ebook-platform-artifacts-dev

# Step Functions
STEP_FUNCTIONS_ARN=arn:aws:states:us-east-1:<account_id>:stateMachine:ebook-platform-dev-topic-pipeline
# Leave blank to hit real AWS Step Functions.
# Set to http://localhost:8083 to use the local SFN docker emulator.
STEP_FUNCTIONS_ENDPOINT=

# EventBridge Scheduler (for per-topic schedules)
SCHEDULE_GROUP_NAME=ebook-platform-dev-topics
SCHEDULER_ROLE_ARN=arn:aws:iam::<account_id>:role/ebook-platform-dev-scheduler

# Cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=

# SES
SES_SENDER_EMAIL=noreply@yourdomain.com
OWNER_EMAIL=owner@yourdomain.com

# Secrets Manager (name of the secret holding the OpenAI API key)
OPENAI_SECRET_NAME=ebook-platform/openai-key

# Local API server base URLs (used by Jupyter notebook and UI)
ADMIN_API_BASE_URL=http://localhost:8000
PUBLIC_API_BASE_URL=http://localhost:8000

# Dev Cognito admin credentials (for notebook auth helper cell)
ADMIN_USERNAME=dev-admin@yourdomain.com
ADMIN_PASSWORD=
